{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/grab-resource:path*",
      "destination": "/api/grab-resource.js?resourceSuffix=:path*"
    },
    {
      "source": "/config.js",
      "destination": "/api/config.js"
    },
    {
      "source": "/grabmaps-loader.js",
      "destination": "/api/grabmaps-loader.js"
    },
    {
      "source": "/vendor/:path*",
      "destination": "/api/vendor/:path*"
    }
  ]
}
